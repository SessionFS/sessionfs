---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Pricing — SessionFS" activeNav="pricing" description="SessionFS pricing: free during beta. Storage-based pricing at v1.0.">
  <section class="pt-32 pb-20 px-5 relative noise">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-6" style="font-family: 'Plus Jakarta Sans';">Free during beta.</h1>
      <p class="text-lg mb-2" style="color: #c9d1d9;">All features are free during beta. Pricing takes effect at v1.0.</p>
      <p class="text-base mb-16" style="color: #9ca3af;">Storage-based pricing, not seat-based. Pay for what you store.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 text-left mb-16">
        <div class="glass p-5"><div class="text-sm font-medium mb-1" style="color: #9ca3af;">Free</div><div class="text-2xl font-bold mb-4">$0</div><ul class="text-sm space-y-2" style="color: #c9d1d9;"><li>&#10003; Capture 8 tools</li><li>&#10003; Resume 4 tools</li><li>&#10003; Local search</li></ul></div>
        <div class="glass p-5"><div class="text-sm font-medium mb-1" style="color: #9ca3af;">Starter</div><div class="text-2xl font-bold mb-4">$4.99<span class="text-sm font-normal" style="color: #9ca3af;">/mo</span></div><ul class="text-sm space-y-2" style="color: #c9d1d9;"><li>&#10003; 500MB cloud sync</li><li>&#10003; Dashboard</li><li>&#10003; Manual Judge</li></ul></div>
        <div class="glass p-5" style="border-color: rgba(79,156,247,0.4);"><div class="text-sm font-medium mb-1" style="color: #4f9cf7;">Pro</div><div class="text-2xl font-bold mb-4">$9.99<span class="text-sm font-normal" style="color: #9ca3af;">/mo</span></div><ul class="text-sm space-y-2" style="color: #c9d1d9;"><li>&#10003; Auto-audit + auto-sync</li><li>&#10003; Handoff + PR/MR</li><li>&#10003; LLM Summary</li><li>&#10003; Project context</li></ul></div>
        <div class="glass p-5"><div class="text-sm font-medium mb-1" style="color: #9ca3af;">Team</div><div class="text-2xl font-bold mb-4">$19.99<span class="text-sm font-normal" style="color: #9ca3af;">/user/mo</span></div><ul class="text-sm space-y-2" style="color: #c9d1d9;"><li>&#10003; 1GB/user storage</li><li>&#10003; Team management</li><li>&#10003; Priority support</li></ul></div>
      </div>
      <div class="glass p-8 max-w-lg mx-auto"><h3 class="text-xl font-bold mb-2">Enterprise</h3><p class="text-sm mb-4" style="color: #c9d1d9;">Self-hosted, HIPAA DLP, SAML SSO, SLA, dedicated support.</p><a href="/enterprise/" class="inline-flex items-center justify-center text-white font-semibold rounded-lg px-7 py-3 hover:brightness-110 transition" style="background: #4f9cf7;">Contact Us</a></div>
    </div>
  </section>
</BaseLayout>
